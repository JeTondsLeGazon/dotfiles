unalias grh
function grh() {
  git fetch
  git reset --hard origin/$(git branch --show-current)
}

# Custom functions
fpath=( ~/.zshfunc "${fpath[@]}" )
for file in ~/.zshfunc/*; do
  autoload -Uz $file
done

# Confidential functions
if [ -f ~/.zshfunc_confidential.sh ]; then
  source ~/.zshfunc_confidential.sh
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Zellij pane title - show git repo name on directory change
if [ -n "$ZELLIJ" ]; then
  _zellij_update_pane_title() {
    # Check if we're in a git repository
    if git rev-parse --git-dir > /dev/null 2>&1; then
      # Get the repo name (last component of git root path)
      local repo_name=$(basename "$(git rev-parse --show-toplevel)")
      zellij action rename-pane "$repo_name" 2>/dev/null
    else
      # Fallback to current directory name
      local dir_name=$(basename "$PWD")
      zellij action rename-pane "$dir_name" 2>/dev/null
    fi
  }
  
  # Hook that runs whenever directory changes
  chpwd_functions+=(_zellij_update_pane_title)
  
  # Also run on shell startup
  _zellij_update_pane_title
fi

