eval "$(zellij setup --generate-auto-start zsh)"
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"


POWERLEVEL9K_DISABLE_CONFIGURATION_WIZARD=True 
ZSH_THEME="powerlevel10k/powerlevel10k"


# Pyenv
export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"

# EDITOR AND CONFIG
export ZVM_VI_EDITOR="nvim"
export K9S_EDITOR="nvim"
export ZVM_VI_INSERT_ESCAPE_BINDKEY=jk

plugins=(git zsh-autosuggestions zsh-syntax-highlighting zsh-bat zsh-vi-mode)
source $ZSH/oh-my-zsh.sh

# FZF
source /usr/share/doc/fzf/examples/key-bindings.zsh

# Aliases
alias act="[[ -d .venv/ ]] && source .venv/bin/activate"
alias docker-compose="docker compose"
alias uva="uv sync --all-groups --all-extras; uv pip install debugpy"
alias lzd="lazydocker"
alias todo="dooit"
alias rf="ruff format"
alias rc="ruff check"
alias rcf="ruff check --fix"

# GIT
alias gs="git status"
alias gl="git logo"
alias ga="git add"
alias gau="git add -u"
alias gc="git commit"
alias gp="git push"
alias gcm="git commit -m"
alias gco="git checkout" 
alias gd="git diff"
alias gr="git restore"
alias gpl="git pull"
alias gf="git fetch"
alias gr="git rebase"
alias grc="git rebase --continue"

# Custom functions
fpath=( ~/.zshfunc "${fpath[@]}" )
for file in ~/.zshfunc/*; do
  autoload -Uz $file
done


# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


# . "$HOME/snap/code/198/.local/share/../bin/env"
. "$HOME/.local/bin/env"

# opencode
export PATH=/home/hugo/.opencode/bin:$PATH
